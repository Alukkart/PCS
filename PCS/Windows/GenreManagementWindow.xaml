<Window x:Class="PCS.Windows.GenreManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление жанрами"
        Width="930"
        Height="560"
        MinWidth="850"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Width="90" Margin="0,0,8,0" Click="CreateNewButton_OnClick" Content="Новый" />
            <Button Width="120" Margin="0,0,8,0" Click="SaveButton_OnClick" Content="Сохранить" />
            <Button Width="90" Margin="0,0,8,0" Click="DeleteButton_OnClick" Content="Удалить" />
            <Button Width="90" Click="CloseButton_OnClick" Content="Закрыть" />
        </WrapPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="GenresDataGrid"
                      Margin="0,0,10,0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      SelectionChanged="GenresDataGrid_OnSelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Binding="{Binding Name}" Header="Название жанра" />
                    <DataGridTextColumn Width="2*" Binding="{Binding Description}" Header="Описание" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1"
                    Padding="10"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    CornerRadius="6">
                <StackPanel>
                    <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Название жанра" />
                    <TextBox x:Name="NameTextBox" Margin="0,0,0,10" />

                    <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Описание" />
                    <TextBox x:Name="DescriptionTextBox"
                             Height="170"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   Foreground="#666666"
                   Text="Удаление жанра удаляет все связанные книги (каскадное удаление)." />
    </Grid>
</Window>
