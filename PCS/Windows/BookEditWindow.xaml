<Window x:Class="PCS.Windows.BookEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Книга"
        Width="560"
        Height="520"
        MinWidth="520"
        MinHeight="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Название" />
        <TextBox x:Name="TitleTextBox" Grid.Row="1" Margin="0,0,0,10" />

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Год публикации" />
                <TextBox x:Name="PublishYearTextBox" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Количество в наличии" />
                <TextBox x:Name="QuantityTextBox" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="3" Margin="0,0,0,4" FontWeight="SemiBold" Text="ISBN-10 или ISBN-13" />
        <TextBox x:Name="IsbnTextBox" Grid.Row="4" Margin="0,0,0,10" />

        <Grid Grid.Row="5" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Авторы" />
                <ListBox x:Name="AuthorsListBox"
                         DisplayMemberPath="FullName"
                         Height="160"
                         SelectionMode="Extended" />
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                <TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Жанры" />
                <ListBox x:Name="GenresListBox"
                         DisplayMemberPath="Name"
                         Height="160"
                         SelectionMode="Extended" />
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="6"
                   Margin="0,8,0,0"
                   VerticalAlignment="Top"
                   Foreground="#666666"
                   Text="Выберите минимум одного автора и один жанр. Для мультивыбора используйте Ctrl или Shift." />

        <StackPanel Grid.Row="7"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button x:Name="SaveButton" Width="100" Margin="0,0,8,0" Click="SaveButton_OnClick" Content="Сохранить" />
            <Button Width="100" Click="CancelButton_OnClick" Content="Отмена" />
        </StackPanel>
    </Grid>
</Window>

